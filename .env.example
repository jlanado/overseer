# --- Model backend ---
# Two supported modes. Pick ONE.
#
# MODE A — Direct Anthropic API (simplest, real cost per token):
#   Set ANTHROPIC_API_KEY below, leave the LITELLM_* block empty.
#
# MODE B — Local models via your LiteLLM proxy (free, self-hosted):
#   Leave ANTHROPIC_API_KEY empty, fill in the LITELLM_* block instead.
#   Used by both the Reviewer/Security agents (CrewAI) and the Fixer node
#   (Claude Code, via ANTHROPIC_BASE_URL / ANTHROPIC_AUTH_TOKEN).

# --- Mode A: Claude direct ---
ANTHROPIC_API_KEY=

# --- Mode B: LiteLLM proxy ---
LITELLM_BASE_URL=http://192.168.10.102:4000
LITELLM_API_KEY=sk-your-litellm-key
# Claude Code hardcodes sonnet/opus/haiku internally — these remap those
# aliases to real model names registered in your LiteLLM proxy.
ANTHROPIC_MODEL=coder-large
ANTHROPIC_SMALL_FAST_MODEL=coder
# Exact model string for the Reviewer/Security CrewAI agents — copy this
# from your LiteLLM UI (Model Information column), not the short alias.
REVIEWER_MODEL=ollama/qwen2.5-coder:14b

# --- Postgres ---
POSTGRES_USER=overseer
POSTGRES_PASSWORD=changeme_local_dev_only
POSTGRES_DB=overseer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Gitea ---
GITEA_URL=http://gitea:3000
RUNNER_TOKEN=paste_token_from_gitea_admin_actions_runners

# --- Orchestrator ---
# Shared secret Gitea signs webhook payloads with; orchestrator verifies it.
# Leave blank to accept unsigned webhooks (fine for localhost-only testing,
# not for anything reachable beyond your own machine).
WEBHOOK_SECRET=
# Local scratch dir (inside orchestrator container) where repos get cloned per-run.
WORKSPACE_DIR=/workspace
MAX_FIX_ATTEMPTS=3
APPROVAL_TIMEOUT_SECONDS=1800
ORCHESTRATOR_PORT=8000

# --- Registry ---
REGISTRY_URL=localhost:5000

# --- Approval UI ---
APPROVAL_UI_PORT=8501

# --- Langfuse (optional, only needed if you run --profile observability) ---
# PUBLIC_KEY / SECRET_KEY / HOST are read directly by the orchestrator's
# langfuse SDK (each node is @observe()-decorated — see orchestrator/nodes/).
# Leave PUBLIC_KEY/SECRET_KEY blank to disable tracing entirely: the SDK logs
# a warning and no-ops rather than failing the pipeline.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
# NEXTAUTH_SECRET / SALT / ENCRYPTION_KEY are for the self-hosted Langfuse
# server itself (the `langfuse` compose service), not the client SDK above.
LANGFUSE_NEXTAUTH_SECRET=changeme_generate_random
LANGFUSE_SALT=changeme_generate_random
LANGFUSE_ENCRYPTION_KEY=changeme_generate_32_byte_hex

