# --- Claude ---
# Used by CrewAI agents (Reviewer, Security) AND by the Claude Code fixer step.
# Using an API key (not the Pro/Max subscription OAuth token) is intentional here:
# Overseer wraps Claude Code inside a larger orchestrated product, and Anthropic's
# guidance is to use an API key for that case, not a subscription credential.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Postgres ---
POSTGRES_USER=overseer
POSTGRES_PASSWORD=changeme_local_dev_only
POSTGRES_DB=overseer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Gitea ---
GITEA_URL=http://gitea:3000
RUNNER_TOKEN=paste_token_from_gitea_admin_actions_runners

# --- Orchestrator ---
# Shared secret Gitea signs webhook payloads with; orchestrator verifies it.
WEBHOOK_SECRET=changeme_webhook_secret
# Local scratch dir (inside orchestrator container) where repos get cloned per-run.
WORKSPACE_DIR=/workspace
MAX_FIX_ATTEMPTS=3
APPROVAL_TIMEOUT_SECONDS=1800
ORCHESTRATOR_PORT=8000

# --- Registry ---
REGISTRY_URL=localhost:5000

# --- Approval UI ---
APPROVAL_UI_PORT=8501

# --- Langfuse (optional, only needed if you run --profile observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=changeme_generate_random
LANGFUSE_SALT=changeme_generate_random
LANGFUSE_ENCRYPTION_KEY=changeme_generate_32_byte_hex
